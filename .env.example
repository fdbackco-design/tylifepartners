# Google Sheets (상담 신청 자동 기록)
# - 아래 시트를 서비스계정 이메일로 공유해 주세요 (편집 권한)
# - 시트명 기본값: "시트1"
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_SHEET_NAME=
# 본사 시트 (미설정 시 GOOGLE_SHEETS_ID 또는 기본 HQ ID 사용)
# HQ_SPREADSHEET_ID=1tHi28hTsRMVeQCEDiAmLFy9fe_ox8Bp82jPenWfTTqw
# HQ_SHEET_NAME=시트1
# 담당자 G열 저장 후 Apps Script 동기화 (서버 전용 — 프론트 노출 금지)
# HQ_MANAGER_SYNC_WEB_APP_URL=  (배포 → 웹 앱 URL, 반드시 …/exec 로 끝나야 함 — /dev 아님)
# HQ_MANAGER_SYNC_SECRET=       (영문·숫자 등 ASCII만 — Script Properties와 동일)
# 구글 시트 기록 제외 연락처 (쉼표/세미콜론/줄바꿈 구분, 숫자만 사용 권장)
# GOOGLE_SHEETS_PHONE_BLACKLIST=01012345678,010-9876-5432
# 서비스 계정 JSON (둘 중 하나 사용)
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_SERVICE_ACCOUNT_JSON=

