# 이 랜딩이 실제로 서비스되는 기본 URL(프로토콜+호스트, 끝 슬래시 없음).
# 관리자 이메일 링크/UTM 링크 생성기 기본값에 쓰인다. 미설정 시
# https://www.tylifepartners.com 사용(현재 운영 도메인).
NEXT_PUBLIC_SITE_URL=https://www.tylifepartners.com

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin
ADMIN_ID=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# SMTP (메일 알림)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# 알림 수신자 (기본값: dlsdjdmlqlc3@naver.com)
LEAD_NOTIFY_TO=

# Google Sheets (상담 신청 자동 기록)
# - 아래 시트를 서비스계정 이메일로 공유해 주세요 (편집 권한)
# - 시트명 기본값: "시트1"
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_SHEET_NAME=
# 본사 시트 (미설정 시 GOOGLE_SHEETS_ID 또는 기본 HQ ID 사용)
# HQ_SPREADSHEET_ID=1tHi28hTsRMVeQCEDiAmLFy9fe_ox8Bp82jPenWfTTqw
# HQ_SHEET_NAME=시트1
# 담당자 G열 저장 후 Apps Script 동기화 (서버 전용 — 프론트 노출 금지)
# 1) Apps Script → 프로젝트 설정 → 스크립트 속성: HQ_MANAGER_SYNC_SECRET = 아래와 동일한 값
# 2) 배포 → 웹 앱 → URL을 …/exec 로 복사
# HQ_MANAGER_SYNC_WEB_APP_URL=
# HQ_MANAGER_SYNC_SECRET=
# 구글 시트 기록 제외 연락처 (쉼표/세미콜론/줄바꿈 구분, 숫자만 사용 권장)
# GOOGLE_SHEETS_PHONE_BLACKLIST=01012345678,010-9876-5432
# 랜딩 스크롤·히트맵 분석 제외 IP (쉼표/세미콜론/줄바꿈 구분, 회사 고정 IP)
# LANDING_ANALYTICS_IP_EXCLUDE=123.456.789.0
# 서비스 계정 JSON (둘 중 하나 사용)
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_SERVICE_ACCOUNT_JSON=

# FEED Life CRM 유입 동기화 (별도 Supabase 프로젝트) - 기존 DB/Sheets/이메일
# 처리가 전부 끝난 뒤 마지막 단계로만 호출된다. 미설정 시 동기화 자체를
# 조용히 건너뛴다(기존 동작에 영향 없음).
# CRM_LANDING_INGEST_URL=https://<crm-project-ref>.supabase.co/functions/v1/landing-lead-ingest
# CRM_LANDING_INGEST_SECRET=

